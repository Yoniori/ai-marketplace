# ─── Vibe Code Market — Agentic Crew environment ───────────────────────────
# Copy to .env and fill in. Never commit the real .env file.

# ── LLM provider keys (both required with the default routing) ──────────────
# CEO/Manager → Anthropic; worker agents → OpenAI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Model overrides (optional) ──────────────────────────────────────────────
# Any LiteLLM-compatible model string works.
# Default CEO model:    anthropic/claude-3-5-sonnet-20241022
# Default worker model: openai/gpt-4o-mini
#
# CEO_MODEL=anthropic/claude-3-5-sonnet-20241022
# WORKER_MODEL=openai/gpt-4o-mini

# ── Telemetry (CrewAI default is enabled — opt out if you prefer) ───────────
# OTEL_SDK_DISABLED=true
